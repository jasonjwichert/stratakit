---
// See https://starlight.astro.build/reference/overrides/#lastupdated

const { lang, lastUpdated, editUrl } = Astro.locals.starlightRoute;

const commitHistoryUrl = editUrl
	? new URL(editUrl.pathname.replace(/\/edit\//, "/commits/"), editUrl).href
	: undefined;
---

{
	lastUpdated && commitHistoryUrl && (
		<p>
			{Astro.locals.t("page.lastUpdated")}{" "}
			<a href={commitHistoryUrl}>
				<time datetime={lastUpdated.toISOString()}>
					{lastUpdated.toLocaleDateString(lang, { dateStyle: "medium", timeZone: "UTC" })}
				</time>
			</a>
		</p>
	)
}
